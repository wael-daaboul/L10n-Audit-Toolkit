# --- Python bytecode and caches ---
__pycache__/
*.py[cod]
*.pyo
*.pyd

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Test and type-check caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# --- Build and packaging artifacts ---
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

