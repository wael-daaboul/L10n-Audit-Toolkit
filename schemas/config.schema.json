{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "project_root",
    "glossary_file",
    "results_dir",
    "languagetool_dir"
  ],
  "properties": {
    "project_profile": { "type": "string", "minLength": 1 },
    "locale_format": { "type": "string", "enum": ["json", "laravel_php"] },
    "locale_root": { "type": "string" },
    "source_locale": { "type": "string", "minLength": 1 },
    "target_locales": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "project_root": { "type": "string", "minLength": 1 },
    "locales_dir": { "type": "string", "minLength": 1 },
    "en_file": { "type": "string", "minLength": 1 },
    "ar_file": { "type": "string", "minLength": 1 },
    "code_dir": { "type": "string", "minLength": 1 },
    "code_dirs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "locale_paths": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "glossary_file": { "type": "string", "minLength": 1 },
    "results_dir": { "type": "string", "minLength": 1 },
    "languagetool_dir": { "type": "string", "minLength": 1 },
    "usage_patterns": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "allowed_extensions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "profile_overrides": {
      "type": "object",
      "additionalProperties": true
    },
    "ar_locale_qc": {
      "type": "object",
      "properties": {
        "enable_exclamation_style": { "type": "boolean" },
        "enable_long_ui_string": { "type": "boolean" },
        "enable_similar_phrase_variation": { "type": "boolean" },
        "enable_suspicious_literal_translation": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "icu_message_audit": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "strict_branch_matching": { "type": "boolean" },
        "enable_selectordinal": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
