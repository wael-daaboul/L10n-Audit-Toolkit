def test_safe_fixes_apply_only_safe_changes() -> None:
    issues = [
        {
            "source": "locale_qc",
            "key": "trimmed",
            "issue_type": "whitespace",
            "severity": "low",
            "message": "Trim",
            "details": {"old": " hello ", "new": "hello"},
