                    f"`{item['text']}`\n"
                )
        f.write("\n---\n\n")

        f.write(f"## {L['top_used_keys']}\n\n")
        if not usage_counts:
            f.write(f"{L['none']}\n")
        else:
            for k, c in usage_counts[:100]:
